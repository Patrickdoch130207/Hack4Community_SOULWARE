cat > .gitignore << 'EOF'
# Expo
.expo/
dist/
web-build/

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# VSCode
.vscode/

# Python / Django
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
build/
*.sqlite3
venv/
env/
mlenv/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Package lock
package-lock.json
EOF